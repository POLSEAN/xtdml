xtdml_lasso$plot(
title = "Double Machine Learning Diagnostics with Lasso",
col = "steelblue",
pch = 16,
cex = 0.6
)
xtdml_lasso$plot(ask = FALSE, title = "Lasso DML diagnostic plots", col = "steelblue", cex = 0.7)
xtdml_lasso$plot(ask = TRUE, title = "Lasso DML diagnostic plots", col = "steelblue", cex = 0.7)
xtdml_lasso$plot(ask = FALSE, title = "Lasso DML diagnostic plots", col = "steelblue", cex = 0.7)
