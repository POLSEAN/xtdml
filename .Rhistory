learner = c("lasso", "lasso", "nnet", "nnet", "boosting", "boosting"),
panel_approach = c("fd_exact", "cre", "fd_exact", "cre", "fd_exact", "cre"),
rmse_model = c(0.919, 14.312, 1.028, 1.39, 0.681, 1.317),
rmse_l = c(0.173, 1.11, 0.143, 0.183, 0.091, 0.167),
rmse_m = c(0.356, 0.288, 0.162, 0.154, 0.193, 0.213),
)
# Example structure
rmse_df <- data.frame(
learner = c("lasso", "lasso", "nnet", "nnet", "boosting", "boosting"),
panel_approach = c("fd_exact", "cre", "fd_exact", "cre", "fd_exact", "cre"),
rmse_model = c(0.919, 14.312, 1.028, 1.39, 0.681, 1.317),
rmse_l = c(0.173, 1.11, 0.143, 0.183, 0.091, 0.167),
rmse_m = c(0.356, 0.288, 0.162, 0.154, 0.193, 0.213)
)
library(dplyr)
# Select RMSE columns only
rmse_mat <- rmse_df %>%
select(rmse_model, rmse_l, rmse_m, rmse_g)
# Compute correlation matrix
cor_mat <- cor(rmse_mat, use = "pairwise.complete.obs")
cor_mat
library(corrplot)
corrplot(
cor_mat,
method = "color",
type = "upper",
tl.col = "black",
tl.srt = 45,
addCoef.col = "black",
number.cex = 0.8,
col = colorRampPalette(c("blue", "white", "red"))(200)
)
# Example structure
rmse_df <- data.frame(
learner = c("lasso", "lasso", "nnet", "nnet", "boosting", "boosting"),
panel_approach = c("fd_exact", "cre", "fd_exact", "cre", "fd_exact", "cre"),
rmse_model = c(0.919, 14.312, 1.028, 1.39, 0.681, 1.317),
rmse_l = c(0.173, 1.11, 0.143, 0.183, 0.091, 0.167),
rmse_m = c(0.356, 0.288, 0.162, 0.154, 0.193, 0.213)
)
# Select RMSE columns only
rmse_mat <- rmse_df %>%
select(rmse_model, rmse_l, rmse_m)
View(rmse_df)
View(rmse_mat)
# Example structure
rmse_df <- data.frame(
learner = c("lasso", "lasso", "nnet", "nnet", "boosting", "boosting"),
panel_approach = c("fd_exact", "cre", "fd_exact", "cre", "fd_exact", "cre"),
rmse_model = c(0.919, 14.312, 1.028, 1.39, 0.681, 1.317),
rmse_l = c(0.173, 1.11, 0.143, 0.183, 0.091, 0.167),
rmse_m = c(0.356, 0.288, 0.162, 0.154, 0.193, 0.213)
)
library(dplyr)
# Select RMSE columns only
rmse_mat <- rmse_df %>%
select(rmse_model, rmse_l, rmse_m)
# Compute correlation matrix
cor_mat <- cor(rmse_mat, use = "pairwise.complete.obs")
cor_mat
View(cor_mat)
library(corrplot)
corrplot(
cor_mat,
method = "color",
type = "upper",
tl.col = "black",
tl.srt = 45,
addCoef.col = "black",
number.cex = 0.8,
col = colorRampPalette(c("blue", "white", "red"))(200)
)
# Example structure
rmse_df <- data.frame(
learner = c("lasso", "lasso", "nnet", "nnet", "boosting", "boosting"),
panel_approach = c("fd_exact", "cre", "fd_exact", "cre", "fd_exact", "cre"),
rmse_model = c(0.919, 14.312, 1.028, 1.39, 0.681, 1.317),
rmse_l = c(0.173, 1.11, 0.143, 0.183, 0.091, 0.167),
rmse_m = c(0.356, 0.288, 0.162, 0.154, 0.193, 0.213)
)
library(dplyr)
rmse_df <- rmse_df %>%
mutate(rmse_lm = rmse_l * rmse_m)
# Select RMSE columns including the product
rmse_mat <- rmse_df %>%
select(rmse_model, rmse_l, rmse_m, rmse_lm)
# Correlation matrix
cor_mat <- cor(rmse_mat, use = "pairwise.complete.obs")
cor_mat
library(corrplot)
corrplot(
cor_mat,
method = "color",
type = "upper",
tl.col = "black",
tl.srt = 45,
addCoef.col = "black",
number.cex = 0.8,
col = colorRampPalette(c("blue", "white", "red"))(200)
)
View(rmse_df)
